# ══════════════════════════════════════════════════════
# n8n-prospector — Variáveis de Ambiente
# Copie para .env e preencha com suas chaves
# ══════════════════════════════════════════════════════

# ── APIs de dados (obrigatório pelo menos Google Maps) ──
GOOGLE_MAPS_API_KEY=
FOURSQUARE_API_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# ── IA para qualificação (escolha um) ──
# Groq = gratuito (Llama 3.3 70B), Anthropic = pago (Claude Haiku)
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# ── WhatsApp (Evolution API) ──
EVOLUTION_API_KEY=minha-chave-segura
EVOLUTION_INSTANCE=bookou

# ── n8n ──
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=trocar-esta-senha

# ── Segmento de prospecção ──
SEGMENT_ID=barbearias

# ── Segurança da API do scraper ──
# Se definido, todas as requisições precisam do header x-api-key
SCRAPER_API_KEY=

# ── Chatbot / Anti-ban ──
# Número do vendedor/dono que recebe notificações de leads quentes
HANDOFF_PHONE=5562995513691
# URL webhook do n8n para notificações (opcional)
HANDOFF_WEBHOOK_URL=
# Limite de novos envios por dia (auto warm-up: 10→20→50)
DAILY_SEND_LIMIT=10
# Delay entre envios em ms (randomizado entre MIN e MAX)
MIN_DELAY_MS=45000
MAX_DELAY_MS=90000
# Horário de envio (fora disso, não envia)
WORKING_HOURS_START=9
WORKING_HOURS_END=18

# ── Integração CRM (opcional — se não preencher, leads não vão pro CRM) ──
CRM_API_URL=
CRM_INGEST_API_KEY=
CRM_TENANT_ID=
# Classificações que vão para o CRM (separadas por vírgula)
CRM_INGEST_CLASSES=QUENTE,MORNO

# ── Infraestrutura (defaults OK para começar) ──
ENRICH_CONCURRENCY=3
CACHE_BACKEND=memory
STORAGE_BACKEND=file
